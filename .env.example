# Meta 개발자 앱 > Instagram > API 설정 에서 확인
IG_APP_ID=
IG_APP_SECRET=

# 앱에 등록한 OAuth 리다이렉트 URI와 문자 하나까지 정확히 일치해야 함 (HTTPS 필수)
# 주의: 대시보드의 긴 authorize URL이 아니라, 그 URL 안의 redirect_uri 값만 적을 것
IG_REDIRECT_URI=https://localhost/callback

# CI(GitHub Actions)에서만 사용. 로컬은 tokens.json을 씀
# 주의: 이 파일은 커밋된다. 주석 줄에도 실제 값을 절대 넣지 말 것.
# IG_ACCESS_TOKEN=
# IG_USER_ID=
